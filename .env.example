# Copy to .env (git-ignored) and fill in. Load with:  set -a; . ./.env; set +a

# Hugging Face token used to download the gated nvidia/Cosmos-* models.
#
# MUST be a *user access token* with Read scope, minted at
# https://huggingface.co/settings/tokens (starts with `hf_`, ~37 chars).
# An OAuth token (`hf_oau...`, ~800 chars, from a browser sign-in) will pass
# repo-read probes but CRASH the in-pod `hf auth login` with
# `KeyError: 'accessToken'` — see PROGRESS.md.
#
# Before first use, accept the license on each gated repo page listed in the
# DIG skill's references/setup.md (Cosmos-Predict2-*, Cosmos-AnomalyGen-*,
# Cosmos-AnomalyGen-PCB-Dataset, Cosmos-AnomalyGen-Glass-Masks, Spark-AnomalyGen-USD).
HF_TOKEN=hf_your_token_here
